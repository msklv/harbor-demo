# ============================================================
#  harbor.env — настройки для Home Lab
#  Отредактируйте перед запуском setup.sh
# ============================================================

# Хостнейм или IP вашего сервера
# НЕ используйте localhost / 127.0.0.1
HARBOR_HOSTNAME=harbor.homelab.local

# Пароль администратора (логин: admin)
HARBOR_ADMIN_PASSWORD=Harbor@HomeLab2025!

# HTTP-порт (используется при USE_HTTPS=false или как редирект)
HARBOR_HTTP_PORT=80

# HTTPS-порт
HARBOR_HTTPS_PORT=443

# true  — HTTPS (рекомендуется, даже для homelab)
# false — только HTTP (нужно добавить insecure-registry в docker daemon)
HARBOR_USE_HTTPS=true
